{
  "dashboard": {
    "title": "Debezium SQL Server CDC - Overview",
    "tags": ["debezium", "cdc", "sqlserver"],
    "timezone": "browser",
    "panels": [
      {
        "title": "Connector Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "kafka_connect_connector_status{connector=\"sqlserver-debezium-connector\"}",
            "legendFormat": "{{status}}"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "textMode": "name"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"options": {"running": {"color": "green", "text": "RUNNING"}}}
            ]
          }
        }
      },
      {
        "title": "Task Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "kafka_connect_connector_task_status{connector=\"sqlserver-debezium-connector\"}",
            "legendFormat": "Task {{task}}: {{status}}"
          }
        ]
      },
      {
        "title": "CDC Records Per Second",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "rate(kafka_connect_source_connector_source_record_poll_total{connector=\"sqlserver-debezium-connector\"}[1m])",
            "legendFormat": "Records Polled/s"
          },
          {
            "expr": "rate(kafka_connect_source_connector_source_record_write_total{connector=\"sqlserver-debezium-connector\"}[1m])",
            "legendFormat": "Records Written/s"
          }
        ],
        "yaxes": [
          {"label": "Records/sec", "format": "short"},
          {"format": "short"}
        ]
      },
      {
        "title": "Snapshot Progress",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "(debezium_snapshot_completed_tables / debezium_snapshot_total_tables_count) * 100",
            "legendFormat": "Snapshot %"
          }
        ],
        "options": {
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 50, "color": "yellow"},
                {"value": 100, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "title": "Total CDC Events Captured",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "kafka_connect_source_connector_source_record_poll_total{connector=\"sqlserver-debezium-connector\"}",
            "legendFormat": "Total Events"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "title": "Connector Lag",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "kafka_connect_source_connector_source_record_poll_total{connector=\"sqlserver-debezium-connector\"} - kafka_connect_source_connector_source_record_write_total{connector=\"sqlserver-debezium-connector\"}",
            "legendFormat": "Pending Records"
          }
        ],
        "yaxes": [
          {"label": "Records", "format": "short"},
          {"format": "short"}
        ]
      },
      {
        "title": "Error Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "rate(kafka_connect_connector_failed_task_restarts_total{connector=\"sqlserver-debezium-connector\"}[5m])",
            "legendFormat": "Task Restarts/s"
          }
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [0.1], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "name": "High Error Rate Alert"
        }
      },
      {
        "title": "Connection Status",
        "type": "table",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "debezium_metrics_Connected",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {"id": "organize", "options": {"excludeByName": {"Time": true}}}
        ]
      }
    ],
    "refresh": "10s",
    "schemaVersion": 27,
    "version": 1,
    "uid": "debezium-overview"
  }
}
